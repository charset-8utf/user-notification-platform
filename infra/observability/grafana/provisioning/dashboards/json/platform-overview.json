{
  "uid": "unp-platform",
  "title": "Platform Overview",
  "tags": ["user-notification-platform"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Targets UP",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum(up)", "legendFormat": "up" }
      ]
    },
    {
      "id": 2,
      "title": "HTTP RPS (user-service)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"user-service\"}[1m]))",
          "legendFormat": "rps"
        }
      ]
    },
    {
      "id": 3,
      "title": "HTTP 5xx rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{status=~\"5..\"}[5m])) by (application)",
          "legendFormat": "{{application}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Outbox pending",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 12 },
      "targets": [
        { "expr": "app_outbox_pending", "legendFormat": "pending" }
      ]
    },
    {
      "id": 5,
      "title": "Outbox relay rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 12 },
      "targets": [
        {
          "expr": "rate(app_outbox_relay_published_total[5m])",
          "legendFormat": "published/s"
        },
        {
          "expr": "rate(app_outbox_relay_failed_total[5m])",
          "legendFormat": "failed/s"
        }
      ]
    },
    {
      "id": 6,
      "title": "Kafka consumer lag",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 12 },
      "targets": [
        { "expr": "app_kafka_consumer_lag_total", "legendFormat": "lag" }
      ]
    },
    {
      "id": 7,
      "title": "Emails sent",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "sum(rate(app_notification_email_sent_total[5m])) by (operation)",
          "legendFormat": "{{operation}}"
        }
      ]
    },
    {
      "id": 8,
      "title": "gRPC request duration p95",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(app_grpc_server_requests_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        }
      ]
    }
  ]
}
