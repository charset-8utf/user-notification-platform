# Скопируйте в .env: cp .env.example .env
# В production замените все значения на сильные секреты.

# --- Межсервисная аутентификация ---
APP_SERVICE_JWT_SECRET=dev-service-jwt-secret-change-in-production-min-32b

# --- Kafka SASL_SSL + SCRAM (опционально) ---
# Сертификаты: infra/tls/generate-dev-certs.sh && infra/kafka/generate-kafka-certs.sh
APP_KAFKA_SECURITY_ENABLED=false
KAFKA_USER_SERVICE_PASSWORD=dev-kafka-user-service-secret
KAFKA_NOTIFICATION_SERVICE_PASSWORD=dev-kafka-notification-service-secret

# --- Spring Cloud Config ---
CONFIG_SERVER_PORT=8888
CONFIG_SERVER_HOST=config-server

# --- API Gateway / BFF ---
API_GATEWAY_PORT=8080
WEB_BFF_PORT=8090

# --- Observability ---
ZIPKIN_PORT=9411
ZIPKIN_ENDPOINT=http://zipkin:9411/api/v2/spans
TRACING_ENABLED=false
TRACING_SAMPLE_PROBABILITY=1.0

# --- Профили Spring ---
USER_SERVICE_PROFILES=kafka,redis,jwt,management,docker
# Cloud: добавьте ,cloud
# USER_SERVICE_PROFILES=kafka,redis,jwt,management,docker,cloud
# NOTIFICATION_SERVICE_PROFILES=rest,kafka,redis,management,docker,cloud

# --- JWT ---
APP_JWT_SECRET=dev-jwt-secret-change-in-production-min-32-chars
APP_JWT_ISSUER=user-service
# OIDC (profiles cloud+auth): gateway JWKS from host
# APP_JWT_ISSUER_URI=http://host.docker.internal:8180/realms/platform
SCHEMA_REGISTRY_PORT=8085
APP_API_KEY_ENABLED=false
APP_API_KEYS=demo-integration-key
KEYCLOAK_PORT=8180

# --- БД и seed-данные ---
DB_USER=postgres
DB_PASSWORD=postgres
KEYSTORE_PASSWORD=changeit
APP_SEED_ADMIN_PASSWORD=admin123
APP_SEED_USER_PASSWORD=user123

# --- Порты на хосте ---
USER_SERVICE_HTTPS_PORT=8443
USER_SERVICE_MANAGEMENT_PORT=8081
NOTIFICATION_SERVICE_HTTPS_PORT=8444
NOTIFICATION_SERVICE_MANAGEMENT_PORT=8082
POSTGRES_PUBLISH_PORT=5432
MONGO_PUBLISH_PORT=27017
REDIS_PUBLISH_PORT=6379
KAFKA_PUBLISH_PORT=9092
MAILPIT_UI_PORT=8025

# --- Observability (profile observability) ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
PROMETHEUS_PORT=9091
GRAFANA_PORT=3000
LOKI_PORT=3100
ALERTMANAGER_PORT=9093
