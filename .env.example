# Скопируйте в .env в корне платформы: cp .env.example .env
# В production замените все значения на сильные секреты (не коммитьте .env).

# --- Межсервисная аутентификация (фаза 2) ---
# Один и тот же секрет для user-service (профиль rest) и notification-service.
APP_SERVICE_JWT_SECRET=dev-service-jwt-secret-change-in-production-min-32b

# --- Kafka SASL_SSL + SCRAM (фаза 4, compose) ---
# Сертификаты: infra/tls/generate-dev-certs.sh && infra/kafka/generate-kafka-certs.sh
APP_KAFKA_SECURITY_ENABLED=true
KAFKA_USER_SERVICE_PASSWORD=dev-kafka-user-service-secret
KAFKA_NOTIFICATION_SERVICE_PASSWORD=dev-kafka-notification-service-secret

# --- TLS east-west (фаза 3, профиль rest) ---
# RestClient user-service доверяет CA из notification-truststore.p12 (перегенерация: infra/tls/generate-dev-certs.sh)
# APP_NOTIFICATION_REST_INSECURE_SSL=false
# APP_NOTIFICATION_REST_TRUST_STORE=classpath:notification-truststore.p12

# --- Профили Spring ---
# По умолчанию: Kafka + Redis, без REST между сервисами.
USER_SERVICE_PROFILES=kafka,redis,jwt
# JWT (фаза 1): access ~15m, refresh 7d, отзыв refresh в Redis
APP_JWT_SECRET=dev-jwt-secret-change-in-production-min-32-chars
# Для Postman + HTTP Basic поверх JWT: добавьте профиль local
# USER_SERVICE_PROFILES=kafka,redis,jwt,local
# Для REST-режима user-service: rest,redis
# NOTIFICATION_SERVICE_PROFILES=kafka,redis
# Для прямого POST /api/notifications/email (dev/E2E): rest,kafka,redis

# --- БД и приложение user-service ---
DB_USER=postgres
DB_PASSWORD=postgres
KEYSTORE_PASSWORD=changeit
APP_SEED_ADMIN_PASSWORD=admin123
APP_SEED_USER_PASSWORD=user123

# --- Порты на хосте ---
USER_SERVICE_HTTPS_PORT=8443
USER_SERVICE_MANAGEMENT_PORT=8081
NOTIFICATION_SERVICE_HTTPS_PORT=8444
NOTIFICATION_SERVICE_MANAGEMENT_PORT=8082
# Профиль management: actuator только на management-порту (фаза 5)
# USER_SERVICE_PROFILES=kafka,redis,jwt,management
KEYSTORE_PASSWORD=changeit
POSTGRES_PUBLISH_PORT=5432
MONGO_PUBLISH_PORT=27017
REDIS_PUBLISH_PORT=6379
# Опционально: пароль Redis (user-service и notification-service получают его через SPRING_DATA_REDIS_PASSWORD).
# REDIS_PASSWORD=change-me-in-prod
# TTL кэша пользователя (ISO-8601), только user-service:
# APP_CACHE_REDIS_TTL=PT1H
KAFKA_PUBLISH_PORT=9092
MAILPIT_UI_PORT=8025

# --- Observability (profile observability) ---
PROMETHEUS_PORT=9091
GRAFANA_PORT=3000
METRICS_ENV=local
